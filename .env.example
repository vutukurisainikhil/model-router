# Required — copy this to .env and fill in your values
# Never commit the real .env to version control.

# ── Router authentication ─────────────────────────────────────────────────────
# Plain key (unrestricted):         dev-key-1
# Scoped key (chat scope only):     prod-key-1:chat
# Multiple scopes:                  admin-key:chat,admin
# Multiple keys (comma-separated):  dev-key-1,prod-key-1:chat
ROUTER_API_KEYS=your-router-key-here

# ── DigitalOcean Serverless Inference ─────────────────────────────────────────
# Secret: never logged, never echoed in responses.
DO_INFERENCE_API_KEY=your-do-api-key-here
DO_INFERENCE_BASE_URL=https://inference.do-ai.run/v1
DO_DEFAULT_MODEL=llama3.3-70b-instruct

# ── Operational ───────────────────────────────────────────────────────────────
MAX_BODY_BYTES=262144
APP_ENV=development
SERVICE_VERSION=0.1.0
